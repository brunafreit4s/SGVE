<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <environment names="Development">
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
        <link rel="stylesheet" href="~/css/Login.css" />
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0-beta1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-0evHe/X+R7YkIZDRvuzKMRqM+OrBnVFBL6DOitfPri4tjfHxaWutUpFmBp4vmVor" crossorigin="anonymous">
        <script src="https://kit.fontawesome.com/4a127b145c.js" crossorigin="anonymous"></script>
        <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
    </environment>

    <title>@ViewBag.Title</title>

</head>
<body>
    @{
        ViewData["Title"] = "Painel de Acesso";
    }

    <header>
        <div class="container">
            <nav class="navbar bg-light fixed-top border-bottom">
                <div class="container-fluid">
                    <a class="navbar-brand" href="#"><span class="navbar-text text-primary">SGVE - Sistema Gerenciador de Vendas e Estoque</span></a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar" aria-controls="offcanvasNavbar">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasNavbar" aria-labelledby="offcanvasNavbarLabel">
                        <div class="offcanvas-header">
                            <h5 class="offcanvas-title text-primary h1" id="offcanvasNavbarLabel">Acessar</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                        </div>
                        <div class="row col-lg-12 offcanvas-body">
                            <ul class="navbar-nav justify-content-end form-group-1 pe-3">
                                @if (ViewBag.Codigo == 3)
                                {
                                    <li class="row col-lg-12 nav-item dropdown">
                                        <a class="nav-link dropdown-toggler" href="#" id="offcanvasNavbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Funcionário
                                        </a>
                                        <ul class="dropdown-menu img-responsive" aria-labelledby="offcanvasNavbarDropdown">
                                            <li><a class="dropdown-item col-lg-12" href="@Url.Action("Cadastrar", "Funcionario")"><i class="fa-solid fa-folder-plus"></i> Cadastrar</a></li>
                                            <li><hr class="dropdown-divider col-lg-12"><a class="dropdown-item" href="@Url.Action("Consultar", "Funcionario")"><i class="fa-solid fa-magnifying-glass"></i> Pesquisar</a></li>
                                            <li></li>
                                        </ul>
                                    </li>
                                }
                                @if (ViewBag.Codigo == 3 || ViewBag.Codigo == 4)
                                {
                                    <li class="row col-lg-12 nav-item dropdown">
                                        <a class="nav-link dropdown-toggler" href="#" id="offcanvasNavbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Produto
                                        </a>
                                        <ul class="dropdown-menu img-responsive" aria-labelledby="offcanvasNavbarDropdown">
                                            <li><a class="dropdown-item col-lg-12" href="@Url.Action("Cadastrar", "Produto")"><i class="fa-solid fa-file-circle-plus"></i> Incluir</a></li>
                                            <li><hr class="dropdown-divider col-lg-12"><a class="dropdown-item" href="@Url.Action("Consultar", "Produto")"><i class="fa-solid fa-magnifying-glass"></i> Pesquisar</a></li>
                                            <li></li>
                                        </ul>
                                    </li>
                                    <li class="row col-lg-12 nav-item dropdown">
                                        <a class="nav-link dropdown-toggler" href="#" id="offcanvasNavbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Estoque
                                        </a>
                                        <ul class="dropdown-menu img-responsive" aria-labelledby="offcanvasNavbarDropdown">
                                            <li><a class="dropdown-item" href="@Url.Action("Consultar", "Estoque")"><i class="fa-solid fa-file-circle-check"></i> Consultar</a></li>
                                            <li></li>
                                        </ul>
                                    </li>
                                }
                                @if (ViewBag.Codigo == 3 || ViewBag.Codigo == 4 || ViewBag.Codigo == 2)
                                {
                                    <li class="row col-lg-12 nav-item dropdown">
                                        <a class="nav-link dropdown-toggler" href="#" id="offcanvasNavbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            Venda
                                        </a>
                                        <ul class="dropdown-menu img-responsive" aria-labelledby="offcanvasNavbarDropdown">
                                            <li><a class="dropdown-item" href="@Url.Action("Consultar", "Funcionario")"><i class="fa-solid fa-cart-plus"></i> Nova Venda</a></li>
                                            <li></li>
                                        </ul>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>
        </div>
    </header>

    <div class="container">
        <div class="col-lg-12">
            <h1 class="display-4">Bem Vindo(a)</h1>
            <h3>@ViewBag.NomeLogado</h3>
            <hr />
            <br />
            <h4>@ViewBag.Title</h4>
            <p>
                <div class="text-info"><b>Informações gerais do sistema. </b></div>
            </p>
            <hr />
            <br />
            <div class="divProdutos">
                <h3>Produtos</h3>

                <!--Div that will hold the pie chart-->
                <div id="chart_div"></div>
            </div>
        </div>
    </div>

    <footer class="bg-light border-top footer text-muted">
        <div class="container">
            <p>
                SGVE - Sistema Gerenciador de Vendas e Estoque
            </p>
        </div>
    </footer>
    <script src="https://code.jquery.com/jquery-3.2.1.slim.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0-beta1/dist/js/bootstrap.bundle.min.js" integrity="sha384-pprn3073KE6tl6bjs2QrFaJGz5/SUsLqktiwsUTF55Jfv3qYSDhgCecCxMW52nD2" crossorigin="anonymous"></script>
</body>
</html>

<script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
<script type="text/javascript">
    var vLista_Produtos = @Html.Raw(Json.Serialize(ViewBag.Lista_Produtos));
    // Load the Visualization API and the corechart package.
    google.charts.load('current', { 'packages': ['corechart'] });

    // Set a callback to run when the Google Visualization API is loaded.
    google.charts.setOnLoadCallback(drawChart);

    // Callback that creates and populates a data table,
    // instantiates the pie chart, passes in the data and
    // draws it.
    function drawChart() {
        if (vLista_Produtos != null) {
            // Create the data table.
            var data = new google.visualization.DataTable();
            data.addColumn('string', 'Topping');
            data.addColumn('number', 'Slices');
            vLista_Produtos.forEach(function (item) {
                data.addRows([
                    [item.nomE_PROD, item.quantidadE_PROD],
                ]);
            });

            // Set chart options
            var options = {
                'title': 'Quantidade de Produtos disponíveis em Estoque',
                'width': 600,
                'height': 500
            };

            // Instantiate and draw our chart, passing in some options.
            var chart = new google.visualization.PieChart(document.getElementById('chart_div'));
            chart.draw(data, options);
        }
    }
</script>